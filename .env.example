# Pharma-Flow environment variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file (it is in .gitignore).

# ── Required ─────────────────────────────────────────────────────────────────

# Groq LLM API key (get yours at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Institutional email for NCBI Entrez API (required by NCBI Terms of Service)
ENTREZ_EMAIL=yossifmesalam@gmail.com

# ── Optional: LLM Tuning ─────────────────────────────────────────────────────

# LLM_MODEL=llama-3.1-8b-instant
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_TIMEOUT_SECONDS=30.0
# LLM_MAX_RETRIES=3
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=800

# ── Optional: NCBI ───────────────────────────────────────────────────────────

# NCBI API key — raises rate limit from 3 to 10 req/s (get at https://www.ncbi.nlm.nih.gov/account/)
# ENTREZ_API_KEY=your_ncbi_api_key_here

# Number of PubMed articles to fetch per ingestion query
# PUBMED_MAX_RESULTS=10

# Path to the local PubMed corpus file (default shown)
# PUBMED_DATA_PATH=data/raw/pubmed.txt

# ── Optional: RAG Tuning ─────────────────────────────────────────────────────

# EMBEDDING_MODEL=all-MiniLM-L6-v2
# RAG_CHUNK_SIZE=300
# RAG_CHUNK_OVERLAP=50
# RAG_RETRIEVAL_K=3